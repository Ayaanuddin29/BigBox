@{
    ViewData["Title"] = "SubCategory Master";
    Layout = "_Layout";
}

<h2 class="mb-3">📂 Sub-Category Master</h2>

<div class="row mb-3">
    <div class="col-md-4">
        <label class="form-label fw-bold">Select Category</label>
        <select id="ddlCategory" class="form-select"></select>
    </div>
    <div class="col-md-8 text-end">
        <button class="btn btn-primary mt-4" id="btnAdd">➕ Add Sub-Category</button>
    </div>
</div>

<div id="noSubCategoryMessage" class="alert alert-warning text-center" style="display:none;">
    ⚠️ No sub-categories available for this category.
</div>
<table class="table table-bordered table-striped text-center" id="subcategoryTable">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Name Ar</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<!-- Modal -->
<div class="modal fade" id="subcategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">SubCategory</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="SubCategoryId" />
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input type="text" id="SubCategoryName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Name Ar</label>
                    <input type="text" id="SubCategoryNameAr" dir="rtl" class="form-control" />
                </div>
                <div class="form-check">
                    <input type="checkbox" id="IsActive" class="form-check-input" checked />
                    <label class="form-check-label">Active</label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-success" id="btnSave">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/subcategory.js"></script>
}