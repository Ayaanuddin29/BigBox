@model ComplaintManagement.Util.Models.UserManagement.AssociateGroupDto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Edit Associate Group";
    Layout = "_Layout";
}

<h3>Edit Associate Group</h3>
<hr />

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="AssociateGroupId" />

    <div class="row">
        <div class="col-md-6">
            <label class="form-label">Group Name</label>
            <input asp-for="GroupName" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Group Email</label>
            <input asp-for="GroupEmailId" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <input asp-for="Active" type="checkbox" class="form-check-input" />
        <label class="form-check-label">Active</label>
    </div>

    <hr />

    <div class="row">
        <!-- Support Staff -->
        <div class="col-md-6">
            <h5>Support Staff</h5>
            <select asp-for="SelectedStaffIds"
                    asp-items="@(new MultiSelectList(Model.StaffList,"AssociateId","AssociateName", Model.SelectedStaffIds))"
                    multiple class="form-control"
                    style="height:250px;">
            </select>
        </div>

        <!-- Support Manager -->
        <div class="col-md-6">
            <h5>Support Managers</h5>
            <select asp-for="SelectedManagerIds"
                    asp-items="@(new MultiSelectList(Model.ManagerList,"AssociateId","AssociateName", Model.SelectedManagerIds))"
                    multiple class="form-control"
                    style="height:250px;">
            </select>
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Update</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</form>