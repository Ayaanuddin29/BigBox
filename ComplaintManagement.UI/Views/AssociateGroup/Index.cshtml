@model List<ComplaintManagement.Util.Models.UserManagement.AssociateGroupDto>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Associate Groups";
    Layout = "_Layout";
}

<h3 class="mb-3">Associate Groups</h3>

<a asp-action="Create" class="btn btn-primary mb-3">
    <i class="bi bi-plus-circle"></i> Create New Group
</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Group Name</th>
            <th>Email</th>
            <th>Active</th>
            <th width="120px">Action</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.AssociateGroupId</td>
                    <td>@item.GroupName</td>
                    <td>@item.GroupEmailId</td>
                    <td>
                        @if (item.Active == true)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.AssociateGroupId"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">No records found</td>
            </tr>
        }
    </tbody>
</table>