@model IEnumerable<ComplaintManagement.Util.Models.Incident.TicketDto>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewBag.Title = "Process Relation";
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />

<div class="container-fluid">

    <div class="card">

        <div class="card-header">
            <h5>Manage Relations</h5>
        </div>

        <div class="card-body">

            <div class="row mb-3">

                <div class="col-md-2">
                    <label>Select Module</label>
                    <select class="form-control">
                        <option>Incident</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label>Filter</label>
                    <select class="form-control">
                        <option>By Category</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label>Access</label>
                    <select class="form-control">
                        <option>Admin Access</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label>&nbsp;</label>
                    <button class="btn btn-success form-control">Filter</button>
                </div>

            </div>

            <div class="row mb-3">

                <div class="col-md-4">

                    <label>Select Relation Type</label>

                    <select id="relationType" class="form-control">

                        <option value="">Select Relation Type</option>

                        @foreach (var item in ViewBag.RelationTypes)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }

                    </select>

                </div>

            </div>

            <table id="ticketTable" class="table table-bordered table-striped">

                <thead>

                    <tr>

                        <th>
                            <input type="checkbox" id="selectAll" />
                        </th>

                        <th>Ticket Id</th>
                        <th>Service</th>
                        <th>Status</th>
                        <th>User</th>
                        <th>Creation Date</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var t in Model)
                    {

                        <tr>

                            <td>
                                <input type="checkbox" class="ticketCheck"
                                       value="@t.TicketId" />
                            </td>

                            <td>@t.TicketId</td>
                            <td>@t.Service</td>
                            <td>@t.Status</td>
                            <td>@t.User</td>
                            <td>@t.CreationDate.ToString("dd-MM-yyyy HH:mm")</td>

                        </tr>

                    }

                </tbody>

            </table>

            <div class="mt-2">

                <a href="#" id="selectAllLink">Select All</a> |
                <a href="#" id="clearAllLink">Clear All</a>

            </div>

            <div class="text-right mt-3">

                <button id="btnLinkChild" class="btn btn-success">
                    Link Child Records
                </button>

            </div>

        </div>

    </div>


    <div class="card mt-4">

        <div class="card-header">
            <h5>Relation Established</h5>
        </div>

        <div class="card-body">

            <table id="relationTable" class="table table-bordered">

                <thead>
                    <tr>
                        <th>Parent Ticket</th>
                        <th>Child Ticket</th>
                        <th>Relation Type</th>
                    </tr>
                </thead>

                <tbody id="relationBody">

                    <tr>
                        <td colspan="3" class="text-center text-danger">
                            No record Found
                        </td>
                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<script>

    $(document).ready(function () {

        $('#ticketTable').DataTable({
            pageLength: 10
        });

        loadRelations();

    });

    $("#selectAll").click(function () {

        $(".ticketCheck").prop('checked', $(this).prop('checked'));

    });

    $("#selectAllLink").click(function () {

        $(".ticketCheck").prop('checked', true);

    });

    $("#clearAllLink").click(function () {

        $(".ticketCheck").prop('checked', false);

    });


    $("#btnLinkChild").click(function () {

        var selected = [];

        $(".ticketCheck:checked").each(function () {

            selected.push($(this).val());

        });

        var relationType = $("#relationType").val();

        if (selected.length == 0) {
            alert("Please select at least one ticket");
            return;
        }

        if (relationType == "") {
            alert("Please select relation type");
            return;
        }

        $.ajax({

            url: 'https://localhost:51647/api/processrelation/link',

            type: 'POST',

            contentType: 'application/json',

            data: JSON.stringify({

                parentId: @ViewBag.ParentId,

                childIds: selected,

                relationTypeId: relationType

            }),

            success: function () {

                alert("Relation Created Successfully");

                location.reload();

            }

        });

    });

    var parentId = '@ViewBag.ParentId';

    function loadRelations() {

        $.ajax({

            url: 'https://localhost:51647/api/processrelation/relations/' + parentId,

            type: 'GET',

            success: function (data) {

                var html = "";

                if (data.length == 0) {

                    html += `<tr>
                            <td colspan="3" class="text-center text-danger">
                            No record Found
                            </td>
                            </tr>`;
                }
                else {

                    $.each(data, function (i, item) {

                        html += `<tr>
                                <td>${item.parentId}</td>
                                <td>${item.childId}</td>
                                <td>${item.relationType}</td>
                                </tr>`;
                    });
                }

                $("#relationBody").html(html);

            }

        });
    }

</script>