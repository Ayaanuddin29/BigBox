@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model ComplaintManagement.UI.Models.UserViewModel

@{
    ViewData["Title"] = "Profile";
    Layout = "_Layout";
}

<h3>Profile Information</h3>

<form asp-controller="Profile" asp-action="Update" method="post">

    <!-- ✅ BASIC INFORMATION (TOP SECTION) -->
    <div class="card mb-3">
        <div class="card-header">
            <strong>Basic Information</strong>
        </div>
        <div class="card-body">
            <div class="row">

                <div class="col-md-6 mb-3">
                    <label>Username</label>
                    <input asp-for="username" class="form-control" readonly />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Email</label>
                    <input asp-for="email" class="form-control" />
                </div>

                @* <div class="col-md-6 mb-3">
                    <label>Password</label>
                    <input type="password" name="password" class="form-control" placeholder="Enter new password" />
                </div> *@

                <div class="col-md-6 mb-3">
                    <label>Phone</label>
                    <input asp-for="phone" class="form-control" />
                </div>

                <!-- ✅ Department Dropdown -->
                <div class="col-md-6 mb-3">
                    <label>Department</label>
                    <select asp-for="department" class="form-control"
                            asp-items="@(new SelectList(ViewBag.Departments, "Id", "Name", Model.department))">
                        <option value="">-- Select Department --</option>
                    </select>
                </div>

            </div>
        </div>
    </div>

    <!-- ✅ TABS -->
    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#contact">Contact</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#work">Work</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#preferences">Preferences</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#location">Location</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#address">Address</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#security">Security</a>
        </li>
    </ul>

    <!-- ✅ TAB CONTENT -->
    <div class="tab-content p-3 border border-top-0">

        <!-- CONTACT -->
        <div class="tab-pane fade show active" id="contact">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Phone</label>
                    <input asp-for="phone" class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Email</label>
                    <input asp-for="email" class="form-control" />
                </div>
            </div>
        </div>

        <!-- WORK -->
        <div class="tab-pane fade" id="work">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Division</label>
                    <select asp-for="division" class="form-control"
                            asp-items="@(new SelectList(ViewBag.Divisions, "Id", "Name"))">
                        <option value="">--Select Division--</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Region</label>
                    <select asp-for="region" class="form-control"
                            asp-items="@(new SelectList(ViewBag.Regions, "Id", "Name"))">
                        <option value="">--Select Region--</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- PREFERENCES -->
        <div class="tab-pane fade" id="preferences">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-check mt-4">
                        <input asp-for="email_alert" type="checkbox" class="form-check-input" />
                        <label class="form-check-label">Email Alerts</label>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-check mt-4">
                        <input asp-for="sms_alert" type="checkbox" class="form-check-input" />
                        <label class="form-check-label">SMS Alerts</label>
                    </div>
                </div>
            </div>
        </div>

        <!-- LOCATION -->
        <div class="tab-pane fade" id="location">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Country</label>
                    <select asp-for="country" class="form-control"
                            asp-items="@(new SelectList(ViewBag.Countries, "Id", "Name"))">
                        <option value="">--Select Country--</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label>State</label>
                    <select asp-for="state" class="form-control"
                            asp-items="@(new SelectList(ViewBag.States, "Id", "Name"))">
                        <option value="">--Select State--</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label>City</label>
                    <select asp-for="city" class="form-control"
                            asp-items="@(new SelectList(ViewBag.Cities, "Id", "Name"))">
                        <option value="">--Select City--</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Location</label>
                    <select asp-for="location" class="form-control"
                            asp-items="@(new SelectList(ViewBag.Locations, "Id", "Name"))">
                        <option value="">--Select Location--</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- ADDRESS -->
        <div class="tab-pane fade" id="address">
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label>Address</label>
                    <textarea asp-for="address" class="form-control"></textarea>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Zip Code</label>
                    <input asp-for="zip" class="form-control" />
                </div>
            </div>
        </div>

        <!-- SECURITY -->
        <div class="tab-pane fade" id="security">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Secret Question</label>
                    <input asp-for="secret_question" class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Secret Answer</label>
                    <input asp-for="secret_answer" class="form-control" />
                </div>
            </div>
        </div>

    </div>

    <!-- BUTTON -->
    <div class="text-end mt-3">
        <button type="submit" class="btn btn-primary">
            Update Profile
        </button>
    </div>

</form>