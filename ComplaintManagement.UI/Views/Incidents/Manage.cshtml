<script>
    const fileInput = document.getElementById("fileInput");
    const fileGrid = document.getElementById("fileGrid");
    const fileGridBody = fileGrid.querySelector("tbody");
    let selectedFiles = [];
    //Tasks File Gride
    const taskfileInput = document.getElementById("taskfileInput");
    const taskfileGrid = document.getElementById("taskfileGrid");
    const filetaskGridBody = taskfileGrid.querySelector("tbody");
    let selectedtaskFiles = [];

    taskfileInput.addEventListener("change", function () {
        for (let file of taskfileInput.files) {
            selectedtaskFiles.push(file);
        }
        rendertaskGrid();
    });


    fileInput.addEventListener("change", function () {
        for (let file of fileInput.files) {
            selectedFiles.push(file);
        }
        renderGrid();
    });

    function rendertaskGrid() {
        filetaskGridBody.innerHTML = "";

        if (selectedtaskFiles.length === 0) {
            taskfileGrid.style.display = "none"; // hide grid if empty
            return;
        }

        taskfileGrid.style.display = "table"; // show grid if files exist

        selectedtaskFiles.forEach((file, index) => {
            let row = `<tr>
                      <td>${file.name}</td>
                      <td>
                          <span class="delete-icon" onclick="removetaskFile(${index})">&times;</span>
                      </td>
                  </tr>`;
            filetaskGridBody.innerHTML += row;
        });
    }

    function renderGrid() {
        fileGridBody.innerHTML = "";

        if (selectedFiles.length === 0) {
            fileGrid.style.display = "none"; // hide grid if empty
            return;
        }

        fileGrid.style.display = "table"; // show grid if files exist

        selectedFiles.forEach((file, index) => {
            let row = `<tr>
                      <td>${file.name}</td>
                      <td>
                          <span class="delete-icon" onclick="removeFile(${index})">&times;</span>
                      </td>
                  </tr>`;
            fileGridBody.innerHTML += row;
        });
    }

    function removeFile(index) {
        selectedFiles.splice(index, 1);
        renderGrid();
    }
    function removetaskFile(index) {
        selectedtaskFiles.splice(index, 1);
        rendertaskGrid();
    }
    $("#AssignedToDropdown").change(function () {

        var selected = $(this).val();
        //$("#AssociateDropdown").empty();

        if (selected === "Associate") {
            $("#AssociateDropdown").empty();
            $("#AssociateDropdown").show();
            $("#GroupDropdown").hide();

            $("#lblDynamicAssociation").text("Associate");
            $.getJSON('/Master/GetAssociates', function (data) {
                $("#AssociateDropdown").append('<option value="">Select Associate</option>');
                $.each(data, function (i, associate) {
                    $("#AssociateDropdown").append('<option value="' + associate.associate_id + '">' + associate.associate_name + '</option>');
                });
            });
        } else if (selected === "Group") {
            $("#GroupDropdown").empty();
            $("#GroupDropdown").show();
            $("#AssociateDropdown").hide();
            $("#lblDynamicAssociation").text("Group");
            $.getJSON('/Master/GetAssociateGroups', function (data) {
                $("#GroupDropdown").append('<option value="">Select Group</option>');
                $.each(data, function (i, group) {
                    $("#GroupDropdown").append('<option value="' + group.associate_group_id + '">' + group.group_name + '</option>');
                });
            });
        }
    });



    var quill = new Quill('#editor', {
        theme: 'snow',
        modules: {
            toolbar: [
                [{ 'font': [] }, { 'size': [] }],
                ['bold', 'italic', 'underline', 'strike'],
                [{ 'color': [] }, { 'background': [] }],
                [{ 'script': 'sub' }, { 'script': 'super' }],
