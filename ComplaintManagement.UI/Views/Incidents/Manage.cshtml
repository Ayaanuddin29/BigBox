@using ComplaintManagement.UI.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model ComplaintManagement.UI.Models.ManageIncPageViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    Layout = "_Layout";
    ViewBag.Title = "Manage Incident";

    // Get today's date in MM-DD-YYYY format
    string todayDate = DateTime.Now.ToString("yyyy-MM-ddTHH:mm");
}

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
@if (TempData["Message"] != null)
{
    <div id="toastContainer" style="position: fixed; top: 20px; right: 20px; z-index: 9999;"></div>
}


<div class="row">
    <!-- Number -->
    <div class="col-md-6">
        <div class="form-group">
            @* <h2 class="mb-4">Manage Incident - @Model.Number</h2> *@
            <h2 class="mb-4">Manage Incident - @Model.formManageInc.Number</h2>
        </div>
    </div>
    <div class="col-md-6">
        <div class="form-group" style="text-align:right !important">
            <div class="dropdown">
                <button class="btn btn-primary dropdown-toggle"
                        type="button"
                        id="actionsDropdown"
                        data-bs-toggle="dropdown"
                        aria-expanded="false">
                    ⚙️ Actions
                </button>

                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="actionsDropdown">

                    <li>
                        <a class="dropdown-item"
                           href="#"
                           onclick="setInProgress('@Model.formManageInc.Number')">
                            ▶️ Mark as In Progress
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item"
                           href="@Url.Action("Index","ProcessRelation", new { parentId = @Model.formManageInc.Number })">
                            🔗 Manage Relations
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item"
                           href="@Url.Action("CreateCopy","Incidents", new { id = @Model.formManageInc.Number })">
                            📄 Create Copy
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item"
                           href="@Url.Action("Reassign","Incidents", new { incidentId = @Model.formManageInc.Number })">
                            🔄 ReAssign
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item"
                           href="#"
                           onclick="toggleMajorIncident('@Model.formManageInc.Number')">

                            @(Model.formManageInc.MajorIncident
                                ? "⬇️ Unmark Major Incident"
                                : "⬆️ Mark as Major Incident")

                        </a>
                    </li>

                </ul>
                <button type="submit" form="incidentUpdate" class="btn btn-success" style="margin-right: 7px;padding-right: 20px;">💾 Update</button>
            </div>
           
        </div>
    </div>
</div>
@* <div class="card shadow-sm p-4 mb-4"> *@

<form asp-action="UpdateIncident" asp-controller="Incidents" method="post" id="incidentUpdate" class="incident-form">
    @Html.AntiForgeryToken()
    <!-- Buttons -->
    <!--<h5 class="mb-3 text-primary">Incident Details</h5>-->
    <div class="row">
        <!-- Number -->
        <div class="col-md-6">
            <div class="form-group">
                <label>Number</label>
                <input type="text" class="form-control" asp-for="formManageInc.Number" readonly />
            </div>
        </div>
        <!-- Caller -->
        <div class="col-md-6">
            <div class="form-group">
                <label>Caller</label>
                <div class="input-group">
                    <input type="text" class="form-control" asp-for="formManageInc.Caller" readonly />
                    <!-- <button class="btn btn-outline-secondary" type="button">Search Caller</button>
                    <span asp-validation-for="Caller" class="text-danger"></span>-->
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <!-- Category -->
        <div class="col-md-6">
            <div class="form-group">


                <label>Category</label>
                @*     <select asp-for="Category" asp-items="Model.Categorys" class="form-control"></select> *@
                @Html.DropDownListFor(m => m.formManageInc.Category, Model.formManageInc.Categorys, "Select Category", new { @class = "form-select" })
            </div>



        </div>
        <!-- Subcategory -->
        <div class="col-md-6">
            <div class="form-group">
                <label>SubCategory </label>
                @Html.DropDownListFor(m => m.formManageInc.SubCategory, Model.formManageInc.SubCategorys, "Select SubCategory", new { @class = "form-select" })
                @*  <span asp-validation-for="SubCategory" class="text-danger"></span> *@
            </div>
        </div>
    </div>
    <div class="row">

        <!-- Service -->
        <div class="col-md-6">
            <div class="form-group">
                <label>Service</label>
                @Html.DropDownListFor(m => m.formManageInc.Service, Model.formManageInc.Services, "Select Service", new { @class = "form-select" })

            </div>
        </div>

        <!-- Urgency -->

        <div class="col-md-6">
            <div class="form-group">
                <label>State</label>
                <select asp-for="formManageInc.State" asp-items="Model.formManageInc.States" class="form-select">
                </select>

                @*  <span asp-validation-for="State" class="text-danger"></span> *@
            </div>
        </div>
    </div>
    <div class="row">
        <!-- Priority -->
        <div class="col-md-6">
            <div class="form-group">
                <label>Configuration Item</label>
                <input type="text" class="form-control" />
            </div>
        </div>
        <!-- State -->
        <div class="col-md-6">
            <div class="form-group">
                <label>Assignment Group</label>
                <input type="text" class="form-control" />
            </div>
        </div>


    </div>
    <div class="row">
        <!-- ShortDescription -->
        <div class="col-md-6">
            <div class="form-group">
                <label>Short Description</label>
                <input type="text" class="form-control" asp-for="formManageInc.ShortDescription" />
            </div>
        </div>
        <!-- Assigned To -->

        <div class="col-md-6">
            <div class="form-group">
                <label>Assigned To</label>
                <input type="text" class="form-control" asp-for="formManageInc.AssignedTo" />
                @* <select class="form-select" asp-for="AssignedTo">
                </select> *@
                @*  <span asp-validation-for="AssignedTo" class="text-danger"></span> *@
            </div>
        </div>

    </div>


    <!-- Description (full row) -->
    <div class="row">
        <div class="col-md-12">
            <div class="form-group">
                @* <label>Description</label>
                <textarea class="form-control" asp-for="Description"></textarea>   *@
                <label>Description</label>
                <div id="editor" style="height: 200px;"></div>
                @*
                <input type="text" class="form-control" asp-for="Description" /> *@
                @*  <div id="editor" style="height:200px;" class="form-control">
                <span asp-for="Description"></span>
                </div> *@
                <textarea class="form-control" asp-for="formManageInc.Description" hidden rows="5"></textarea>

            </div>
        </div>
    </div>
    <br />

    <div class="row">
        <!-- Channel -->
        <div class="col-md-3">
            <div class="form-group">
                <label>Channel</label>
                <select id="Channel" name="Channel" class="form-select"></select>
                @*  <select class="form-select" asp-for="Channel">
                <option value="0">-- None --</option>
                <option value="1">-- Channel 1 --</option>
                </select> *@
            </div>
        </div>
        <!-- State -->
        <div class="col-md-3">
            <div class="form-group">

                <label>Priority</label>
                <select asp-for="formManageInc.Priority" asp-items="Model.formManageInc.Prioritys" class="form-select">
                </select>
            </div>
        </div>

        <!-- Impact -->
        <div class="col-md-3">
            <div class="form-group">
                <label>Impact</label>
                <select asp-for="formManageInc.Impact" asp-items="Model.formManageInc.Impacts" class="form-select">
                </select>

            </div>
        </div>
        <!-- Urgency -->
        <div class="col-md-3">
            <div class="form-group">
                <label>Urgency</label>
                <select class="form-select" asp-for="formManageInc.Urgency" asp-items="Model.formManageInc.Urgencys">
                </select>
            </div>
        </div>
    </div>

    <div class="row"><br /></div>
</form>

<!-- 🔽 Tabs Section Below -->
<div class="card shadow-sm p-4">
    <ul class="nav nav-tabs" id="incidentTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="resolution-tab" data-bs-toggle="tab" data-bs-target="#resolution" type="button" role="tab">Resolution</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="activity-tab" data-bs-toggle="tab" data-bs-target="#activity" type="button" role="tab">Activity</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="task-tab" data-bs-toggle="tab" data-bs-target="#task" type="button" role="tab">Task</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="audit-tab" data-bs-toggle="tab" data-bs-target="#audit" type="button" role="tab">Audit</button>
        </li>
    </ul>
</div>
<div class="tab-content mt-3" id="incidentTabsContent">
    <!-- Resolution Tab -->
    <div class="tab-pane fade show active" id="resolution" role="tabpanel" aria-labelledby="resolution-tab">

        <form id="resolutionForm">

            <!-- Hidden Fields -->
            <input type="hidden" id="resol_id" name="resol_id" value="0" />
            <input type="hidden" name="incid_no" value="@Model.formManageInc.Number" />

            <!-- Resolution Type -->
            <div class="mb-3">
                <label class="form-label">Resolution Type</label><br />
                <input type="radio" name="status" value="1" checked /> Resolution
                <input type="radio" name="status" value="2" class="ms-3" /> Recovery
            </div>

            <!-- Summary -->
            <div class="mb-3">
                <label class="form-label">Summary</label>
                <input type="text" name="summary" id="summary" class="form-control" placeholder="Enter Summary" />
            </div>

            <!-- Details -->
            <div class="mb-3">
                <label class="form-label">Details</label>
                <textarea name="details" id="details" class="form-control" rows="4" placeholder="Enter resolution details here..."></textarea>
            </div>

            <!-- Accept / Reject -->
            <div class="mb-3">
                <label class="form-label">Resolution Acceptance</label>
                <select id="ddlAccept" name="solution_accept_or_reject" class="form-control">
                    <option value="">Select</option>
                    <option value="true">Accept</option>
                    <option value="false">Reject</option>
                </select>
            </div>

            <!-- Reject Reason -->
            <div class="mb-3" id="rejectDiv" style="display:none;">
                <label class="form-label">Reason For Rejection</label>
                <textarea id="txtReject" name="reason_for_rejection" class="form-control"></textarea>
            </div>

            <!-- File Upload -->
            <div class="mb-3">
                <label class="form-label">Attach File</label>
                <input type="file" name="files" multiple class="form-control" />
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-success" onclick="saveResolution()">💾 Save Resolution</button>

        </form>

    </div>

    <!-- Activity Tab -->


    <div class="tab-pane fade" id="activity" role="tabpanel" aria-labelledby="activity-tab">
        <h5 class="mb-3">New Activity</h5>
        <form id="incidentactForm" asp-action="CreateIncidentActivity" asp-controller="Incidents" method="post" class="incident-form" enctype="multipart/form-data">
            <!-- Work Notes Input -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">

                    <div class="row mb-3">
                        <div class="col-md-3" style="width: 20% !important;">
                            <label class="col-form-label">Summary</label>
                        </div>
                        <div class="col-md-9" style="width: 80% !important;">
                            <textarea class="form-control" asp-for="formIncActivity.Summary" rows="4"></textarea>
                            <span asp-validation-for="formIncActivity.Summary" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3" style="width: 20% !important;">
                            <label asp-for="formIncActivity.Details" class="col-form-label">Details</label>
                        </div>
                        <div class="col-md-9" style="width: 80% !important;">
                            <div id="editor1" style="height: 200px;"></div>
                            <textarea asp-for="formIncActivity.Details" class="form-control" hidden rows="5"></textarea>
                            <span asp-validation-for="formIncActivity.Details" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3" style="width: 20% !important;">
                            <label class="col-form-label">File Attachment</label>
                        </div>
                        <div class="col-md-9" style="width: 80% !important;">
                            <input type="file" class="form-control" asp-for="formIncActivity.Files" multiple id="fileInput" />
                            <span class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3" hidden>
                        <div class="col-md-3">
                            <label class="col-form-label">Created On</label>
                        </div>
                        <div class="col-md-9">
                            <input type="datetime-local" class="form-control" value="@todayDate" />
                            <span class="text-danger"></span>
                        </div>
                    </div>
                    <table id="fileGrid">
                        <thead>
                            <tr>
                                <th>File Name</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                    <br />
                    <div class="text-end">
                        <!-- Hidden field carries incident.number into activity.incident reference -->
                        <input type="hidden" asp-for="formIncActivity.Incid" value="@Model.formManageInc.Number" />
                        <!--Post an activity-->
                        <button class="btn btn-primary" type="submit">Post</button>
                    </div>

                </div>
            </div>
        </form>
        <!-- Activities Timeline -->
        <h6 class="text-muted mb-3">Activities:</h6>
        <div class="activity-timeline">
            @{
                var distinctActivities = Model.formActivityRead
                ?.GroupBy(a => a.activity_id)
                .Select(g => g.First())
                .ToList() ?? new List<ActivityReadDto>();
            }
            @if (distinctActivities.Any())
            {

                @foreach (var activity in distinctActivities)
                {
                    <div class="card mb-3 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-start">
                                <div><strong>System Administrator</strong></div>
                                <div class="text-muted small ms-3">@activity.Rec_created</div>
                            </div>


                            <p class="mb-0"><strong>Summary:</strong> @activity.Summary</p>
                            <p class="text-muted"><strong>Details:</strong> @activity.Details</p>
                            @*  <p class="mb-0">ActivityId: @activity.activity_id</p> *@
                            @if (activity.Attachments?.Any() == true)
                            {
                                <div class="mt-2">
                                    <h6>Attachments:</h6>
                                    @foreach (var att in activity.Attachments)
                                    {
                                        var base64Image = $"data:image/png;base64,{Convert.ToBase64String(att.FileData)}";
                                        <div class="border p-2 mb-1">
                                            <!-- Hyperlink that opens modal -->
                                            <a href="#" data-bs-toggle="modal" data-bs-target="#imgModal_@att.AttachmentId">
                                                @att.FileName
                                            </a>

                                            <!-- Modal -->
                                            <div class="modal fade" id="imgModal_@att.AttachmentId" tabindex="-1" aria-hidden="true">
                                                <div class="modal-dialog modal-lg modal-dialog-centered">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">@att.FileName</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                        </div>
                                                        <div class="modal-body text-center">
                                                            <img src="@base64Image" alt="@att.FileName" style="max-width:100%; height:auto;" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }




                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info">
                    No Activities found.
                </div>
            }

        </div>
    </div>
