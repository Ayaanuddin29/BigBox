    @if (TempData["Message"] != null)
    {
        <text>
                showToast(@Html.Raw(Json.Serialize(TempData["Message"])));
        </text>
    }
            function showToast(message) {
                const toast = $(`
                            <div class="toast align-items-center text-white bg-success border-0 show" role="alert" aria-live="assertive" aria-atomic="true" style="min-width: 250px;">
                                <div class="d-flex">
                                    <div class="toast-body">${message}</div>
                                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                                </div>
                            </div>
                        `);

                $("#toastContainer").append(toast);

                setTimeout(() => {
                    toast.fadeOut(1000, function () {
                        $(this).remove();
                    });
                }, 3000);
            }
        var quill = new Quill('#editor', {
            theme: 'snow'
        });
        var quill1 = new Quill('#editor1', {
            theme: 'snow'
        });
        var quill2 = new Quill('#editortask', {
            theme: 'snow'
        });
        // Load initial value from server (Model.Description)
        var initialContent = '@Html.Raw(Model.formManageInc.Description ?? "")';
        quill.root.innerHTML = initialContent;
        // Sync back to hidden textarea before submit
        var form = document.querySelector('form');
        form.onsubmit = function () {
            document.querySelector('#Description').value = quill.root.innerHTML;
        };
        // Load initial value from server (Model.Description)
        var initialContent1 = '@Html.Raw(Model.formIncActivity.Details ?? "")';
        quill1.root.innerHTML = initialContent1;
        // Sync back to hidden textarea before submit

        $('#incidentactForm').on('submit', function (e) {
            // Debug log to confirm handler is firing
            //alert("Submit triggered");
            //alert("Quill content:", quill1.root.innerHTML);

            // Copy Quill HTML into hidden textarea
            $('#formIncActivity_Details').val(quill1.root.innerHTML);
        });



    });

    function toggleMajorIncident(id) {

        if (!confirm("Are you sure you want to change Major Incident status?"))
            return;

        console.log('hi');
        var apiBase = '@Configuration["ApiSettings:applicationUrl"]';
        console.log(apiBase);
        console.log(apiBase);

        $.ajax({
            url: 'https://localhost:51647/api/Incidents/MarkUnmarkMajorIncident/' + id,
            type: 'POST',
            success: function (response) {

                if (response.success) {

                    showToast(response.message);

                    setTimeout(function () {
                        location.reload();
                    }, 1000);
                }
            },
            error: function (xhr) {
                console.log(xhr);
                alert("Error updating Major Incident");
            }
        });
    }

    function setInProgress(id) {

        if (!confirm("Move this Incident to In Progress?"))
            return;

        $.ajax({
            url: 'https://localhost:51647/api/Incidents/SetInProgress/' + id,
            type: 'POST',
            success: function (response) {

                if (response.success) {

                    showToast(response.message);

                    setTimeout(function () {
                        location.reload();
                    }, 1000);
                }
            },
            error: function () {
                alert("Error updating state");
            }
        });
    }

    function showToast(message) {

    var toast = document.createElement("div");
    toast.innerText = message;

    toast.style.position = "fixed";
    toast.style.bottom = "20px";
    toast.style.right = "20px";
    toast.style.background = "#28a745";
    toast.style.color = "white";
    toast.style.padding = "10px 20px";
    toast.style.borderRadius = "5px";
    toast.style.zIndex = "9999";

    document.body.appendChild(toast);

    setTimeout(function () {
        toast.remove();
    }, 3000);
}

    $("#ddlAccept").change(function () {
        if ($(this).val() === "false") {
            $("#rejectDiv").show();
        } else {
            $("#rejectDiv").hide();
        }
    });

    function SaveResolution() {
        alert('hi');
        var model = {
            resol_id: $("#resol_id").val() || 0,
            incid_no: $("#IncidentId").val(),
            summary: $("#summary").val(),
            details: $("#details").val(),
            status: $("input[name='type']:checked").val(),
            solution_accept_or_reject: $("#ddlAccept").val(),
            reason_for_rejection: $("#txtReject").val(),
            login_created: "admin"
        };

       

        $.ajax({
            url: "https://localhost:51647/api/resolution/save",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(model),
            success: function () {
                loadGrid();
            }
        });
    }

    function loadGrid() {
        var id = $("#IncidentId").val();

        $.get("https://localhost:51647/api/resolution/list/" + id, function (data) {
            var rows = "";

            $.each(data, function (i, item) {

                var status = "";
                if (item.solution_accept_or_reject === true)
                    status = "Accepted";
                else if (item.solution_accept_or_reject === false)
                    status = "Rejected";
                else
                    status = "Waiting";

                rows += `<tr>
                    <td><a onclick="edit(${item.resol_id})">View</a></td>
                    <td>${item.summary}</td>
                    <td>${status}</td>
                </tr>`;
            });

            $("#tblResolution tbody").html(rows);
        });
    }

    function edit(id) {
        $.get("https://localhost:51647/api/resolution/" + id, function (data) {

            $("#resol_id").val(data.resol_id);
            $("#summary").val(data.summary);
            $("#details").val(data.details);

            $("#ddlAccept").val(data.solution_accept_or_reject).trigger("change");
            $("#txtReject").val(data.reason_for_rejection);
        });
    }

</script>
