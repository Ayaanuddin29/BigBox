@model ComplaintManagement.Util.Models.Incident.IncidentReassignModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewBag.Title = "ReAssign Incident";
    Layout = "_Layout";
}

<div class="container-fluid mt-3">

    <div class="card shadow-sm">

        <div class="card-header bg-light">
            <h5 class="mb-0">Manage Assignment / Priority / SLT / Categorization</h5>
        </div>

        <div class="card-body">

            <!-- Tabs -->
            <ul class="nav nav-tabs" id="reassignTabs" role="tablist">

                <li class="nav-item">
                    <button class="nav-link active"
                            data-bs-toggle="tab"
                            data-bs-target="#assignment"
                            type="button">
                        Change Assignment
                    </button>
                </li>

                <li class="nav-item">
                    <button class="nav-link"
                            data-bs-toggle="tab"
                            data-bs-target="#priority"
                            type="button">
                        Change Priority and SLT
                    </button>
                </li>

                <li class="nav-item">
                    <button class="nav-link"
                            data-bs-toggle="tab"
                            data-bs-target="#category"
                            type="button">
                        Change Categorization
                    </button>
                </li>

            </ul>


            <div class="tab-content mt-3">

                <!-- ================================= -->
                <!-- Change Assignment -->
                <!-- ================================= -->

                <div class="tab-pane fade show active" id="assignment">

                    <form id="assignmentForm">

                        <input type="hidden" asp-for="IncidentId" />

                        <div class="row">

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Assigned To</label>
                                <select asp-for="AssignedTo" class="form-select" id="AssignedTo">
                                    <option value="1">Associate</option>
                                    <option value="2">Group</option>
                                </select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Associate</label>
                                <select asp-for="AssociateId" class="form-select" id="AssociateId">
                                    <option value="1">Smart Admin User</option>
                                </select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">ReAssign Reason</label>
                                <select class="form-select">
                                    <option>Select Reason</option>
                                    <option>Workload Balance</option>
                                    <option>Escalation</option>
                                </select>
                            </div>

                        </div>

                        <button type="button"
                                class="btn btn-success"
                                onclick="updateAssignment()">
                            Submit
                        </button>

                    </form>

                </div>


                <!-- ================================= -->
                <!-- Change Priority -->
                <!-- ================================= -->

                <div class="tab-pane fade" id="priority">

                    <form id="priorityForm">

                        <input type="hidden" asp-for="IncidentId" />

                        <div class="row">

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Priority</label>
                                <select asp-for="PriorityId" class="form-select" id="PriorityId"></select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">SLT</label>
                                <select asp-for="SltId" class="form-select" id="SltId">
                                    <option value="1">1 Day SLT</option>
                                    <option value="2">3 Days SLT</option>
                                    <option value="3">5 Days SLT</option>
                                </select>
                            </div>

                        </div>

                        <button type="button"
                                class="btn btn-success"
                                onclick="updatePriority()">
                            Submit
                        </button>

                    </form>

                </div>


                <!-- ================================= -->
                <!-- Change Categorization -->
                <!-- ================================= -->

                <div class="tab-pane fade" id="category">

                    <form id="categoryForm">

                        <input type="hidden" asp-for="IncidentId" />

                        <div class="row">

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Incident ID</label>
                                <input class="form-control"
                                       value="@Model.IncidentId"
                                       readonly />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Contact</label>
                                <input class="form-control"
                                       value="@Model.Contact"
                                       readonly />
                            </div>

                        </div>


                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Summary</label>
                                <textarea class="form-control"
                                          rows="2"
                                          readonly>@Model.Summary</textarea>
                            </div>

                        </div>


                        <div class="row">

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Category</label>
                                <select asp-for="CategoryId" class="form-select" id="CategoryId"></select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Type</label>
                                <select asp-for="TypeId" class="form-select" id="TypeId"></select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Service</label>
                                <select asp-for="ServiceId" class="form-select" id="ServiceId"></select>
                            </div>

                        </div>

                        <button type="button"
                                class="btn btn-success"
                                onclick="updateCategory()">
                            Submit
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>


<!-- Scripts -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>

    $(document).ready(function () {

        var incidentId = $('#IncidentId').val();

        loadDropdown("https://localhost:51647/api/Master/robox_m_priority", "#PriorityId", "-- Select Priority --");
        loadCategories();

    });

    function loadDropdown(apiUrl, ddlSelector, defaultText) {
        $.ajax({
            url: apiUrl,
            type: "GET",
            success: function (data) {
                var ddl = $(ddlSelector);
                ddl.empty();
                if (defaultText) ddl.append($("<option></option>").val("").html(defaultText));
                $.each(data, function (i, item) {
                    ddl.append($("<option></option>").val(item.id).html(item.name));
                });
            },
            error: function (xhr) {
                console.error("Error loading " + ddlSelector + ":", xhr);
            }
        });
    }

    function loadPriorities() {

        $.get('/api/Master/Priority', function (data) {

            $('#PriorityId').empty();

            $.each(data, function (i, item) {

                $('#PriorityId').append(
                    `<option value="${item.id}">${item.name}</option>`
                );

            });

            $('#PriorityId').val('@Model.PriorityId');

        });

    }

    function loadCategories() {
        $.get("/Category/GetAll", function (data) {
            const ddl = $("#CategoryId");
            ddl.empty().append('<option value="">-- Select Category --</option>');
            $.each(data, function (i, item) {
                ddl.append(`<option value="${item.id}">${item.name}</option>`);
            });
            $('#CategoryId').val('@Model.CategoryId');

            loadTypes(@Model.TypeId);
        });
    }

    function loadCategories11() {

        $.get('/api/Category', function (data) {

            $('#CategoryId').empty();

            $.each(data, function (i, item) {

                $('#CategoryId').append(
                    `<option value="${item.categoryId}">${item.categoryName}</option>`
                );

            });

            $('#CategoryId').val('@Model.CategoryId');

            loadTypes(@Model.TypeId);

        });

    }

    function loadTypes(selectedType) {

        const categoryId = $("#CategoryId").val();
        const url = categoryId
            ? `/SubCategory/GetByCategory?categoryId=${categoryId}`
            : `/SubCategory/GetAll`;

        $.get(url, function (data) {
            const ddl = $("#TypeId");
            ddl.empty().append('<option value="">-- Select Sub Category --</option>');
            $.each(data, function (i, item) {
                ddl.append(`<option value="${item.id}">${item.name}</option>`);
            });

            if (selectedType)
                $('#TypeId').val(selectedType);

            loadServices(@Model.ServiceId);
        });
    }

    function loadTypes11(selectedType) {

        var categoryId = $('#CategoryId').val();

        $.get('/api/SubCategory/' + categoryId, function (data) {

            $('#TypeId').empty();

            $.each(data, function (i, item) {

                $('#TypeId').append(
                    `<option value="${item.typeId}">${item.typeName}</option>`
                );

            });

            if (selectedType)
                $('#TypeId').val(selectedType);

            loadServices(@Model.ServiceId);

        });

    }

    function loadServices(selectedService) {
        const subCategoryId = $("#TypeId").val();

        const url = subCategoryId
            ? `/Service/GetBySubCategory?subCategoryId=${subCategoryId}`
            : `/Service/GetAll`;

        $.get(url, function (data) {
            const ddl = $("#ServiceId");
            ddl.empty();
            ddl.append(`<option value="">-- Select Service --</option>`);
            $.each(data, function (i, item) {
                ddl.append(`<option value="${item.id}">${item.name}</option>`);
            });
            if (selectedService)
                $('#ServiceId').val(selectedService);
        });       
    }

    function loadServices11(selectedService) {

        var typeId = $('#TypeId').val();

        $.get('/api/Service/' + typeId, function (data) {

            $('#ServiceId').empty();

            $.each(data, function (i, item) {

                $('#ServiceId').append(
                    `<option value="${item.serviceId}">${item.serviceName}</option>`
                );

            });

            if (selectedService)
                $('#ServiceId').val(selectedService);

        });

    }

    $('#CategoryId').change(function () {

        loadTypes();

    });

    $('#TypeId').change(function () {

        loadServices();

    });

    function updateAssignment() {

        $.ajax({
            url: '/api/IncidentReassign/UpdateAssignment',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                incidentId: $('#IncidentId').val(),
                assignedTo: $('#AssignedTo').val(),
                associateId: $('#AssociateId').val()
            }),
            success: function () {
                alert("Assignment Updated Successfully");
            }
        });

    }

    function updatePriority() {

        $.ajax({
            url: '/api/IncidentReassign/UpdatePriority',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                incidentId: $('#IncidentId').val(),
                priorityId: $('#PriorityId').val(),
                sltId: $('#SltId').val()
            }),
            success: function () {
                alert("Priority Updated Successfully");
            }
        });

    }

    function updateCategory() {

        $.ajax({
            url: 'https://localhost:51647/api/IncidentReassign/UpdateCategory',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                incidentId: $('#IncidentId').val(),
                categoryId: $('#CategoryId').val(),
                typeId: $('#TypeId').val(),
                serviceId: $('#ServiceId').val()
            }),
            success: function () {
                alert("Category Updated Successfully");
            }
        });

    }

</script>