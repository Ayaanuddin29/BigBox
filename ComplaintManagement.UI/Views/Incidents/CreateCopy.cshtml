@model ComplaintManagement.Util.Models.Incident.IncidentCopyViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Create Copy";
    Layout = "_Layout";
}

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

<h4>Create Copy</h4>

<form asp-action="CreateCopy" method="post">

    <input type="hidden" asp-for="ParentTicketId" />

    <div class="card shadow-sm p-4">

        <div class="row">

            <div class="col-md-6">

                <h5>Source</h5>

                <div class="mb-3">
                    <label>Affected User</label>
                    <input class="form-control" asp-for="Contact" readonly />
                </div>

                <div class="mb-3">
                    <label>Assigned To</label>
                    <input class="form-control" asp-for="AssignedTo" readonly />
                </div>

            </div>


            <div class="col-md-6">

                <h5>Target</h5>

                <!-- Number -->
                <div class="mb-3">                   
                        <label>Reference Number</label>
                    <input type="text" class="form-control" asp-for="ParentTicketId" readonly />
                </div>
                <!-- Caller -->
                <div class="mb-3">
                        <label>Caller <span class="text-danger">*</span></label>
                        <div class="input-group">
                        <input type="text" class="form-control" asp-for="Contact" />
                            <button class="btn btn-outline-secondary" type="button">Search Caller</button>
                        <span asp-validation-for="Contact" class="text-danger"></span>
                        </div>
                </div>

                <div class="mb-3">
                    <label>Category</label>
                    <select asp-for="Category"
                            asp-items="Model.CategoryList"
                            class="form-control"
                            id="categoryDropdown">
                        <option value="">Select Category</option>
                    </select>
                </div>
                <div class="mb-3">
    <label>Service Type</label>
    <select asp-for="ServiceType"
            asp-items="Model.ServiceTypeList"
            class="form-control"
            id="serviceTypeDropdown">
        <option value="">Select Service Type</option>
    </select>
</div>
                <div class="mb-3">
                    <label>Service</label>
                    <select asp-for="ServiceItem"
                            class="form-control"
                            asp-items="Model.ServiceList"
                            id="serviceDropdown">
                        <option value="">Select Service</option>
                    </select>
                </div>


                @* <div class="mb-3">
                    <label>Category</label>
                    <input class="form-control" asp-for="Category" />
                </div>

                <div class="mb-3">
                    <label>Service Type</label>
                    <input class="form-control" asp-for="ServiceType" />
                </div>

                <div class="mb-3">
                    <label>Service</label>
                    <input class="form-control" asp-for="ServiceItem" />
                </div> *@

                <div class="mb-3">
                    <label>Summary</label>
                    <input class="form-control" asp-for="Summary" />
                </div>

                <div class="mb-3">
                    @* <label>Description</label>
<textarea class="form-control" asp-for="Description"></textarea> *@

                    <label>Description</label>
                    <div id="editor" style="height: 200px;"></div>
                    <input type="hidden" name="Description" id="hiddenDescription" />
                </div>

                <div class="mb-3">
                    <label>Relation Type</label>
                    <select class="form-control" asp-for="RelationType">
                        <option>Child</option>
                        <option>Related</option>
                    </select>
                </div>

            </div>

        </div>

        <div class="text-end mt-4">
            <button class="btn btn-success">Submit</button>
            <a href="@Url.Action("Manage","Incidents", new { id = Model.ParentTicketId })"
               class="btn btn-secondary">Cancel</a>
        </div>

    </div>

</form>
<script>
    var quill = new Quill('#editor', {
        theme: 'snow',
        modules: {
            toolbar: [
                [{ 'font': [] }, { 'size': [] }],
                ['bold', 'italic', 'underline', 'strike'],
                [{ 'color': [] }, { 'background': [] }],
                [{ 'script': 'sub' }, { 'script': 'super' }],
                [{ 'header': [1, 2, 3, 4, 5, 6, false] }],
                [{ 'align': [] }],
                ['blockquote', 'code-block'],
                [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                [{ 'indent': '-1' }, { 'indent': '+1' }],
                ['link', 'image', 'video'],
                ['clean']
            ]
        }
    });

    // Sync content on form submit
    document.querySelector('form').addEventListener('submit', function () {
        document.querySelector('#hiddenDescription').value = quill.root.innerHTML;
    });

    $("#categoryDropdown").change(function () {
        loadSubCategories();
    });

    $("#serviceTypeDropdown").change(function () {
        loadServices();
    });

    function loadCategories() {
        $.get("/Category/GetAll", function (data) {
            const ddl = $("#categoryDropdown");
            ddl.empty().append('<option value="">-- Select Category --</option>');
            $.each(data, function (i, item) {
                ddl.append(`<option value="${item.id}">${item.name}</option>`);
            });
        });
    }

    function loadSubCategories() {

        const categoryId = $("#categoryDropdown").val();
        const url = categoryId
            ? `/SubCategory/GetByCategory?categoryId=${categoryId}`
            : `/SubCategory/GetAll`;

        $.get(url, function (data) {
            const ddl = $("#serviceTypeDropdown");
            ddl.empty().append('<option value="">-- Select Sub Category --</option>');
            $.each(data, function (i, item) {
                ddl.append(`<option value="${item.id}">${item.name}</option>`);
            });
        });
    }

    function loadServices() {
        const subCategoryId = $("#serviceTypeDropdown").val();

        const url = subCategoryId
            ? `/Service/GetBySubCategory?subCategoryId=${subCategoryId}`
            : `/Service/GetAll`;

        $.get(url, function (data) {
            const ddl = $("#serviceDropdown");
            ddl.empty();
            ddl.append(`<option value="">-- Select Service --</option>`);
            $.each(data, function (i, item) {
                ddl.append(`<option value="${item.id}">${item.name}</option>`);
            });
        });
    }

    $(document).ready(function () {     
        // alert('hi');
        // loadCategories();
        // loadSubCategories();
        // loadServices();        
    });
</script>