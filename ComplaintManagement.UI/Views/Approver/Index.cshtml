@model IEnumerable<ComplaintManagement.Util.Models.UserManagement.ApproverDto>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Manager List";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Approvers</h3> 
</div>

<table class="table table-bordered table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Username</th>
            <th>Alt Username</th>
            <th>Active</th>
            <th>Availability</th>
            <th width="120">Action</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.ManagerCode</td>
                    <td>@item.ManagerName</td>
                    <td>@item.Username</td>
                    <td>@item.AltMgrUsername</td>

                    <td>
                        @if (item.Active)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive</span>
                        }
                    </td>

                    <td>
                        @if (item.Availability)
                        {
                            <span class="badge bg-info text-dark">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Not Available</span>
                        }
                    </td>

                    <td>
                      @*   @if (User.IsInRole("SuperUser") || User.IsInRole("MasterUser"))
                        { *@
                            <a asp-action="Edit"
                               asp-route-id="@item.ManagerCode"
                               class="btn btn-sm btn-warning">
                                Edit
                            </a>
                       @*  }
                        else
                        {
                            <span class="text-muted">No Access</span>
                        } *@
                    </td>

                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center text-muted">
                    No managers found.
                </td>
            </tr>
        }
    </tbody>
</table>