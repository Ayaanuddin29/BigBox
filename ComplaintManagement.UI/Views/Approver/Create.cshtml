@model ComplaintManagement.Util.Models.UserManagement.ApproverDto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Create Manager";
    Layout = "_Layout";
}

<h3 class="mb-3">Create Manager</h3>

<form asp-action="Create" method="post">

    <div class="row">

        <div class="col-md-6 mb-3">
            <label asp-for="ManagerName" class="form-label"></label>
            <input asp-for="ManagerName" class="form-control" />
            <span asp-validation-for="ManagerName" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Username" class="form-label"></label>
            <input asp-for="Username" class="form-control" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="ManagerName2" class="form-label"></label>
            <input asp-for="ManagerName2" class="form-control" />
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="ManagerName3" class="form-label"></label>
            <input asp-for="ManagerName3" class="form-control" />
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="AltMgrUsername" class="form-label">Alternate Manager Username</label>
            <input asp-for="AltMgrUsername" class="form-control" />
        </div>

        <div class="col-md-3 form-check mb-3 mt-4">
            <input asp-for="Active" class="form-check-input" />
            <label asp-for="Active" class="form-check-label"></label>
        </div>

        <div class="col-md-3 form-check mb-3 mt-4">
            <input asp-for="Availability" class="form-check-input" />
            <label asp-for="Availability" class="form-check-label"></label>
        </div>

    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>

</form>

