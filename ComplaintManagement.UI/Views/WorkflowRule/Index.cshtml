@{
    Layout = "_Layout";
    ViewData["Title"] = "Manage Workflow Rules";
}

<h2>Workflow Business Process Rules</h2>

<div class="col-md-1 mt-4">
<button class="btn btn-success mb-3" id="btnNew">+ New</button>
</div>

<table id="tblRules" class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Rule #</th>
            <th>Process Name</th>
            <th>Module Name</th>
            <th>Category</th>
            <th>Service Type</th>
            <th>Service Item</th>
            <th>Priority</th>
            <th>SLT</th>
            <th>Assign To Associate</th>
            <th>Assign To Group</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<!-- INLINE FORM (Hidden by default) -->
<div id="ruleFormContainer" class="card p-3" style="display:none;">
    <h4 id="formTitle">New Workflow Rule</h4>

    <input type="hidden" id="ruleId" />

    <!-- Row 1 -->
    <div class="row">
        <div class="col-md-6 mb-2">
            <label>Process Name</label>
            <input class="form-control" id="ruleName" />
        </div>
        <div class="col-md-6 mb-2">
            <label>Module Name</label>
            <select class="form-select" id="orderType"></select>
        </div>
    </div>

    <div class="row">       
        <div class="col-md-6 mb-2">
           @*  <label>Workflow Unit</label>
            <select class="form-select" id="workflowUnit"></select> *@
            <label>Language</label>
            <select class="form-select" id="language"></select>
        </div>
        <div class="col-md-6 mb-2">
            <label>Category</label>
            <select class="form-select" id="category"></select>
        </div>
    </div>
        <!-- Row 2 -->
    <div class="row">
        <div class="col-md-6 mb-2">
            <label>Priority</label>
            <select class="form-select" id="priority"></select>
        </div>
        <div class="col-md-6 mb-2">
            <label>Service Type</label>
            <select class="form-select" id="serviceType"></select>
        </div>
    </div>   

    <!-- Row 4 -->
    <div class="row">
        <div class="col-md-6 mb-2">
            <label>SLT</label>
            <select class="form-select" id="slt"></select>
        </div>
        <div class="col-md-6 mb-2">
            <label>Service Item</label>
            <select class="form-select" id="serviceItem"></select>
        </div>        
    </div>

    <!-- Row 5 -->
    <div class="row">
        <div class="col-md-6 mb-2">
           
        </div>
        <div class="col-md-6 mb-2">
            <label>Assign To Associate</label>
            <select class="form-select" id="associate"></select>
        </div>
    </div>

    <!-- Row 6 -->
    <div class="row">
        <div class="col-md-6 mb-2">
        </div>
        <div class="col-md-6 mb-2">
            <label>Assign To Group</label>
            <select class="form-select" id="group"></select>
        </div>
    </div>

    <div class="mt-3">
        <button id="btnSave" class="btn btn-success">Save</button>
        <button id="btnCancel" class="btn btn-secondary">Cancel</button>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/workflowRule.js"></script>
}