@{
    Layout = "_Layout";
}

@{
    ViewData["Title"] = "Master Management";
    var tableName = ViewBag.TableName as string;
}

<h2>@tableName Management</h2>
<meta charset="utf-8" />
<div class="row mb-3">
    <div class="col-md-4">
        <input type="text" id="txtName" class="form-control" placeholder="Enter new name" />
    </div>
    <div class="col-md-4">
        <input type="text" id="txtNameAr" class="form-control" dir="rtl" placeholder="Enter new name arabic" />
    </div>
    <div class="col-md-2">
        <button id="btnAdd" class="btn btn-primary">Add</button>
    </div>
</div>

<table class="table table-striped" id="tblMaster">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Name Ar</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

@section Scripts {
    <!-- ✅ Load jQuery first -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/master.js"></script>
    <script>
        var tableName = '@tableName';
    </script>
}
