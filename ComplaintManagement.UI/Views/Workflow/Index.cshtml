@model ComplaintManagement.Util.Models.Workflow.WorkflowSaveModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_Layout";
    ViewData["Title"] = "Manage Workflow Setup";
}

<input type="hidden" id="WorkflowId" value="@Model?.WorkflowId" />
<input type="hidden" id="workflowJson" value='@Html.Raw(Model?.WorkflowJson)' />
<input type="hidden" id="conditionJson" value='@Html.Raw(Model?.ConditionJson)' />

<input type="text" id="WorkflowName" class="form-control mb-2"
       placeholder="Workflow Name"
       value="@Model?.WorkflowName" />

<input type="hidden" id="WorkflowId" />
@* <input type="text" id="WorkflowName" placeholder="Workflow Name" /> *@

<div class="row">
    <div class="col-md-2 toolbox">
        <div draggable="true" class="node" data-type="start">Start</div>
        <div draggable="true" class="node" data-type="condition">Condition</div>
        <div draggable="true" class="node" data-type="assign">Assign</div>
        <div draggable="true" class="node" data-type="status">Set Status</div>
        <div draggable="true" class="node" data-type="notify">Notify</div>
        <div draggable="true" class="node" data-type="end">End</div>
    </div>

    <div class="col-md-10">
        <div id="canvas"></div>
        <div class="modal fade" id="nodeModal">
            <div class="modal-dialog">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5>Edit Node</h5>
                        <button class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">

                        <!-- REQUIRED -->
                        <input type="hidden" id="editNodeId" />

                        <!-- COMMON LABEL -->
                        <div class="mb-2">
                            <label>Label</label>
                            <input id="nodeLabel" class="form-control">
                        </div>

                        <!-- CONDITION -->
                        <div id="editor-condition" class="editor d-none">
                            <div class="mb-2">
                                <label>Field</label>
                                <select id="conditionField" class="form-control">
                                    <option value="Category">Category</option>
                                    <option value="Priority">Priority</option>
                                    <option value="Impact">Impact</option>
                                    <option value="Urgency">Urgency</option>
                                </select>
                            </div>

                            <div class="mb-2">
                                <label>Operator</label>
                                <select id="conditionOperator" class="form-control">
                                    <option value="==">Equals</option>
                                    <option value="!=">Not Equals</option>
                                </select>
                            </div>

                            <div class="mb-2">
                                <label>Value</label>
                                <select id="conditionValueSelect" class="form-control"></select>
                            </div>
                        </div>

                        <!-- ASSIGN -->
                        <div id="editor-assign" class="editor d-none">
                            <div class="mb-2">
                                <label>Assign To</label>
                                <select id="assignType" class="form-control">
                                    <option value="Associate">Associate</option>
                                    <option value="Group">Group</option>
                                </select>
                            </div>

                            <div class="mb-2">
                                <label>Value</label>
                                <select id="assignValue" class="form-control"></select>
                            </div>
                        </div>

                        <!-- STATUS -->
                        <div id="editor-status" class="editor d-none">
                            <div class="mb-2">
                                <label>Status</label>
                                <select id="statusValue" class="form-control"></select>
                            </div>
                        </div>

                        <!-- NOTIFY -->
                        <div id="editor-notify" class="editor d-none">
                            <div class="mb-2">
                                <label>Email</label>
                                <input id="notifyValue" class="form-control" placeholder="user@email.com">
                            </div>
                        </div>

                    </div>


                    <div class="modal-footer">
                        <button class="btn btn-primary" onclick="saveNodeConfig()">Save</button>
                    </div>

                </div>
            </div>
        </div>

        <button onclick="saveWorkflow()">Save Workflow</button>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jsPlumb/2.15.6/js/jsplumb.min.js"></script>

<script src="~/js/workflow.js"></script>
}
