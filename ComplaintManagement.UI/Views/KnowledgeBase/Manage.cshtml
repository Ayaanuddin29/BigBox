@model ComplaintManagement.UI.Models.KBArticleCreateViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "_Layout";
    ViewData["Title"] = "Manage Knowledge Article";
}

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<style>

    .file-card {
        display: flex;
        align-items: center;
        background: #f1f1f1;
        padding: 6px 10px;
        border-radius: 6px;
        border: 1px solid #ddd;
    }

    .file-name {
        margin-right: 10px;
        font-size: 14px;
    }

    .remove-file {
        padding: 2px 6px;
    }

</style>
<div class="container mt-3">

    <div class="card shadow-sm">

        <div class="card-header">
            <h4>Edit Knowledge Article</h4>
        </div>

        <div class="card-body">

            <form asp-action="Manage" asp-controller="KnowledgeBase" method="post" enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="ArticleNumber" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Article Number</label>
                        <input type="text" class="form-control" value="@Model.ArticleNumber" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                </div>



                <div class="row">

                    <div class="col-md-12 mb-3">
                        <label class="form-label">Summary</label>
<textarea asp-for="Summary" class="form-control"></textarea>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-12 mb-3">

                        <label class="form-label">Content</label>

                        <div id="editor" style="height:200px;"></div>

                        <input type="hidden" id="hiddenContent" asp-for="Content" />

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label class="form-label">Category</label>

                        <select id="CategoryId" name="CategoryId" class="form-control">
                            <option value="">Select Category</option>
                        </select>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">Status</label>

                        <select id="StatusId" name="StatusId" class="form-control">
                            <option value="">Select Status</option>
                        </select>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <div class="form-check mt-2">

                            <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />

                            <label class="form-check-label">
                                Featured Article
                            </label>

                        </div>

                    </div>

                </div>

                <!-- FILES & URL SECTION -->

                <div class="card mt-4">

                    <div class="card-header">
                        <h5>Files & URL</h5>
                    </div>

                    <div class="card-body">

                        <div class="row">

                            <!-- LEFT SIDE : FILE ATTACHMENT -->

                            <div class="col-md-6">

                                <label class="form-label">Attach File</label>

                                <input asp-for="UploadFiles" type="file" class="form-control" multiple />

                                <input type="hidden" asp-for="FilePath" />

                                @if (!string.IsNullOrEmpty(Model.FilePath))
                                {
                                    var files = Model.FilePath.Split(",");

                                    <div class="mt-3">
                                        <strong>Attachments:</strong>

                                        <div id="fileContainer" class="d-flex flex-wrap gap-2 mt-2">

                                            @foreach (var file in files)
                                            {
                                                var fileName = System.IO.Path.GetFileName(file);

                                                <div class="file-card" data-path="@file">

                                                    <span class="file-name">
                                                        <a href="@file" target="_blank">@fileName</a>
                                                    </span>

                                                    <button type="button"
                                                            class="btn btn-sm btn-danger remove-file"
                                                            onclick="removeFile(this)">
                                                        ❌
                                                    </button>

                                                </div>
                                            }

                                        </div>
                                    </div>
                                }

                            </div>

                            <!-- RIGHT SIDE : RELATED URL -->

                            <div class="col-md-6">

                                <label class="form-label">Related URLs</label>

                                <div class="input-group mb-3">

                                    <input type="text" id="urlInput" class="form-control" placeholder="http://www.example.com">

                                    <button type="button" class="btn btn-secondary" onclick="addUrl()">+</button>

                                </div>

                                <table class="table table-bordered" id="urlTable">

                                    <thead>
                                        <tr>
                                            <th style="width:120px">Action</th>
                                            <th>URLs</th>
                                        </tr>
                                    </thead>

                                    <tbody>

                                        @if (!string.IsNullOrEmpty(Model.RelatedUrl))
                                        {
                                            var urls = Model.RelatedUrl.Split(",");

                                            foreach (var url in urls)
                                            {
                                                <tr>

                                                    <td>
                                                        <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)">Remove</button>
                                                    </td>

                                                    <td>
                                                        <a href="@url" target="_blank">@url</a>
                                                        <input type="hidden" name="RelatedUrl" value="@url" />
                                                    </td>

                                                </tr>
                                            }
                                        }

                                    </tbody>

                                </table>

                            </div>

                        </div>

                    </div>

                </div>

                <div class="text-end mt-3">

                    <button type="submit" class="btn btn-success">
                        Update Article
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        Cancel
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

<script>

    var quill = new Quill('#editor', {
    theme: 'snow',
    modules: {
    toolbar: [
    ['bold','italic','underline'],
    [{'list':'ordered'},{'list':'bullet'}],
    ['link','image'],
    ['clean']
    ]
    }
    });

    quill.root.innerHTML = document.getElementById("hiddenContent").value;

    document.querySelector('form').addEventListener('submit', function () {
    document.querySelector('#hiddenContent').value = quill.root.innerHTML;
    });

    $(document).ready(function () {

    loadCategories();
    loadStatus();

    });

    function loadCategories() {

    $.get("/KBCategory/GetAll", function (data) {

    const ddl = $("#CategoryId");

    ddl.empty();

    ddl.append('<option value="">Select Category</option>');

    $.each(data, function (i, item) {

    const selected = item.id == '@Model.CategoryId' ? 'selected' : '';

    ddl.append(`<option value="${item.id}" ${selected}>${item.name}</option>`);

    });

    });

    }

    function loadStatus() {

    $.get("/KBStatus/GetAll", function (data) {

    const ddl = $("#StatusId");

    ddl.empty();

    ddl.append('<option value="">Select Status</option>');

    $.each(data, function (i, item) {

    const selected = item.id == '@Model.StatusId' ? 'selected' : '';

    ddl.append(`<option value="${item.id}" ${selected}>${item.name}</option>`);

    });

    });

    }

    function addUrl() {

        var url = document.getElementById("urlInput").value.trim();

        if (url === "") return;

        var table = document.querySelector("#urlTable tbody");

        var row = document.createElement("tr");

        row.innerHTML = `
            <td>
                <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)">Remove</button>
            </td>
            <td>
                <a href="${url}" target="_blank">${url}</a>
                <input type="hidden" name="RelatedUrl[]" value="${url}" />
            </td>
        `;

        table.appendChild(row);

        document.getElementById("urlInput").value = "";
    }

    function removeRow(btn) {

    var row = btn.parentNode.parentNode;
    row.parentNode.removeChild(row);

    }
        function removeFile(btn)
    {
        var card = btn.closest(".file-card");

        card.remove();

        updateFilePaths();
    }

    function updateFilePaths()
    {
        var files = [];

        document.querySelectorAll(".file-card").forEach(function(card){

            files.push(card.getAttribute("data-path"));

        });

        document.querySelector("input[name='FilePath']").value = files.join(",");
    }

</script>