@model ComplaintManagement.UI.Models.KBArticleCreateViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "_Layout";
    ViewData["Title"] = "Create Knowledge Article";
}

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

<div class="container mt-3">

    <div class="card shadow-sm">
        <div class="card-header">
            <h4>Create Knowledge Article</h4>
        </div>

        <div class="card-body">

            <!-- IMPORTANT enctype added -->
            <form asp-action="Create" asp-controller="KnowledgeBase" method="post" enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Article Number</label>
                        <input type="text" class="form-control" value="@Model.ArticleNumber" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                </div>



                <div class="row">

                    <div class="col-md-12 mb-3">
                        <label class="form-label">Summary</label>
                        <textarea asp-for="Summary" class="form-control"></textarea>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-12 mb-3">
                        <label class="form-label">Content</label>
                        <div id="editor" style="height:200px;"></div>
                        <input type="hidden" asp-for="Content" id="hiddenContent"/>
                    </div>

                </div>

                <!-- CATEGORY + STATUS -->

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Category</label>
                        <select id="CategoryId" name="CategoryId" class="form-control">
                            <option value="">Select Category</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Status</label>
                        <select id="StatusId" name="StatusId" class="form-control">
                            <option value="">Select Status</option>
                        </select>
                    </div>

                </div>

                <!-- FILE UPLOAD -->

                <div class="row">

                    <div class="col-md-6">
                        <label class="form-label">Attach Files</label>

                        <input asp-for="UploadFiles" type="file" class="form-control" multiple />

                        <input type="hidden" asp-for="FilePath" />
                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">Related URLs</label>

                        <div class="input-group mb-3">

                            <input type="text" id="urlInput" class="form-control" placeholder="http://www.example.com">

                            <button type="button" class="btn btn-secondary" onclick="addUrl()">+</button>

                        </div>

                        <table class="table table-bordered" id="urlTable">

                            <thead>
                                <tr>
                                    <th style="width:120px">Action</th>
                                    <th>URLs</th>
                                </tr>
                            </thead>

                            <tbody></tbody>

                        </table>

                    </div>

                </div>

                <!-- ARTICLE TYPE -->

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <div class="form-check">
                            <input asp-for="IsGeneralArticle" class="form-check-input" />
                            <label class="form-check-label">
                                General Article
                            </label>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="form-check">
                            <input asp-for="IsTechnicalArticle" class="form-check-input" />
                            <label class="form-check-label">
                                Technical Article
                            </label>
                        </div>
                    </div>

                </div>

                <!-- FEATURED -->

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <div class="form-check">
                            <input asp-for="IsFeatured" class="form-check-input" />
                            <label class="form-check-label">
                                Featured Article
                            </label>
                        </div>
                    </div>

                </div>

                <div class="text-end">
                    <button type="submit" class="btn btn-primary">
                        Create Article
                    </button>
                </div>

            </form>

        </div>

    </div>

</div>

@if (TempData["ArticleNumber"] != null)
{
    <div class="alert alert-success mt-3">
        Knowledge Article created successfully.
        Article Number: <strong>@TempData["ArticleNumber"]</strong>
    </div>
}

<script>

    var quill = new Quill('#editor', {
        theme: 'snow',
        modules: {
            toolbar: [
                ['bold','italic','underline'],
                [{'list':'ordered'},{'list':'bullet'}],
                ['link','image'],
                ['clean']
            ]
        }
    });

    document.querySelector('form').addEventListener('submit', function () {
        document.getElementById('hiddenContent').value = quill.root.innerHTML;
    });

    $(document).ready(function () {
        loadCategories();
        loadStatus();
    });

    function loadCategories() {

        $.get("/KBCategory/GetAll", function (data) {

            const ddl = $("#CategoryId");

            ddl.empty();

            ddl.append('<option value="">Select Category</option>');

            $.each(data, function (i, item) {

                ddl.append(`<option value="${item.id}">${item.name}</option>`);

            });

        });

    }

    function loadStatus() {

        $.get("/KBStatus/GetAll", function (data) {

            const ddl = $("#StatusId");

            ddl.empty();

            ddl.append('<option value="">Select Status</option>');

            $.each(data, function (i, item) {

                ddl.append(`<option value="${item.id}">${item.name}</option>`);

            });

        });

    }
        function addUrl() {

        var url = document.getElementById("urlInput").value.trim();

        if (url === "") return;

        var table = document.querySelector("#urlTable tbody");

        var row = document.createElement("tr");

        row.innerHTML = `
            <td>
                <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)">Remove</button>
            </td>
            <td>
                <a href="${url}" target="_blank">${url}</a>
                <input type="hidden" name="RelatedUrl[]" value="${url}" />
            </td>
        `;

        table.appendChild(row);

        document.getElementById("urlInput").value = "";
    }

    function removeRow(btn) {

        var row = btn.parentNode.parentNode;

        row.parentNode.removeChild(row);

    }

</script>