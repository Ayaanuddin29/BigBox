@model ComplaintManagement.Util.Models.UserManagement.ManageUserRolesDto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Edit Roles";
    Layout = "_Layout";
}

<h4 class="mb-3">
    Manage Roles for :
    <span class="text-primary">@Model.UserName</span>
</h4>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="UserId" />
    <input type="hidden" asp-for="UserName" />

    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th style="width:100px;">Select</th>
                        <th>Role Name</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Roles.Count; i++)
                    {
                        <tr>
                            <td class="text-center">
                                <input type="checkbox"
                                       asp-for="@Model.Roles[@i].IsSelected"
                                       class="form-check-input" />

                                <input type="hidden"
                                       asp-for="@Model.Roles[@i].RoleName" />
                            </td>
                            <td>
                                @Model.Roles[i].RoleName
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-success">
            Save Changes
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Back
        </a>
    </div>
</form>
